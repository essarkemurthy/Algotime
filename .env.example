# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── ICICI Breeze API ──────────────────────────────────────────────────────────
# Get these from https://api.icicidirect.com/ → My API
BREEZE_API_KEY=l11M144986A828y1&67741eX4677SZ07
BREEZE_API_SECRET=878&r7GqY3_4951951sq8073Z76bz407

# Session token — expires every 24 hours. Generate a fresh one each morning:
#   1. Log in to https://api.icicidirect.com/
#   2. Go to "Generate Session" (or use the API to get it programmatically)
#   3. Paste the token below
BREEZE_SESSION_TOKEN=55726631

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Format: postgresql://username:password@host:port/database_name
# One-time setup:
#   1. Install PostgreSQL and create a database:
#        createdb market_data
#   2. Run the schema migration:
#        python scripts/setup_db.py
DB_URL=postgresql://postgres:Abcd1234@localhost:5432/market_data

# ── Intraday signals (VWAP Reversal + ORB alerts) ─────────────────────────────
# All thresholds are optional; the values shown are the built-in defaults.
# These are ALERTS ONLY — the signal engine never places or routes any order.
SIGNAL_BAR_INTERVAL=5m          # bar cadence: 1m | 5m | 15m | 30m
SIGNAL_STRETCH_ATR=1.0          # VWAP-reversal: min ATR-multiple stretch from VWAP
SIGNAL_BULL_RSI_LOW=35
SIGNAL_BULL_RSI_HIGH=55
SIGNAL_BEAR_RSI_LOW=45
SIGNAL_BEAR_RSI_HIGH=65
SIGNAL_RSI_PERIOD=14
SIGNAL_ATR_PERIOD=14
SIGNAL_AVG_VOL_PERIOD=20        # bars for average-volume / ORB volume gate
SIGNAL_ORB_MINUTES=30           # opening-range window from 09:15
SIGNAL_VOL_MULT=1.5             # ORB breakout-bar volume >= VOL_MULT * avg volume

# Notification controls
SIGNAL_NOTIFY_ENABLED=true      # master kill-switch (false => log only, no alerts)
SIGNAL_DRY_RUN=false            # true => print notifications to console, send nothing
SIGNAL_NOTIFY_IN_APP=true       # in-app WebSocket toast (dashboard)
SIGNAL_NOTIFY_TELEGRAM=false    # opt-in; needs TELEGRAM_BOT_TOKEN + TELEGRAM_CHAT_ID
SIGNAL_NOTIFY_WEBHOOK=false     # opt-in; needs SIGNAL_WEBHOOK_URL
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# SIGNAL_WEBHOOK_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Quick-start commands
# ─────────────────────────────────────────────────────────────────────────────
#
# 1. Set up the DB schema (run once):
#      python scripts/setup_db.py
#
# 2. Bulk-download 1 year of historical candles (all universes):
#      python scripts/bulk_download.py
#
#    Or pick a specific universe / interval:
#      python scripts/bulk_download.py --universe indices
#      python scripts/bulk_download.py --universe nifty50
#      python scripts/bulk_download.py --universe all --intervals 1day
#
#    See estimated API calls before committing:
#      python scripts/bulk_download.py --estimate
#
#    Resume an interrupted run (session token may need refresh):
#      python scripts/bulk_download.py --resume
#
#    Verify downloaded data integrity:
#      python scripts/bulk_download.py --verify
#
# 3. Start the live collector (real-time ticks + intraday candles):
#      python collect.py
#
# 4. Start the trading dashboard:
#      python app.py
#      → Open http://localhost:8000
#
# ─────────────────────────────────────────────────────────────────────────────
# Rate limits (Breeze API)
# ─────────────────────────────────────────────────────────────────────────────
# Hard limit:  75 REST calls/minute, ~4500 calls/day
# bulk_download.py uses: 55 calls/min, stops at 4400 calls/day
#
# Full "all" universe (~4600 calls) spans two sessions.
# Use --resume with a fresh session token the next day to finish.
# ─────────────────────────────────────────────────────────────────────────────
