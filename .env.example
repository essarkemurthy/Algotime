# Copy this file to .env and fill in your credentials.
# Generate a fresh BREEZE_SESSION_TOKEN each morning from https://api.icicidirect.com/

BREEZE_API_KEY=your_api_key_here
BREEZE_API_SECRET=your_api_secret_here
BREEZE_SESSION_TOKEN=your_session_token_here

# PostgreSQL connection string for the data collector
# Format: postgresql://username:password@host:port/database_name
# After installing PostgreSQL, create a DB named trading_data, then set this:
DB_URL=postgresql://postgres:your_password@localhost:5432/trading_data
